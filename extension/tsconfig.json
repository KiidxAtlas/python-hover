{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",
    "outDir": "out",
    "lib": ["es2021"],
    "types": ["node", "vscode"],
    "sourceMap": true,
    "rootDir": "..",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "..",
    "paths": {
      "#src/*": ["extension/src/*"],
      "#shared/*": ["shared/*"],
      "#docs-engine/*": ["docs-engine/src/*"]
    }
  },
  "include": ["src/**/*", "../docs-engine/**/*", "../shared/**/*"],
  "exclude": ["node_modules", ".vscode-test"]
}
