{
  "root": true,
  "env": {
    "node": true,
    "es2021": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "eslint:recommended"
  ],
  "ignorePatterns": [
    "out",
    "dist"
  ],
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "off"
  }
}
